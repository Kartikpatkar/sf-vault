{
  "manifest_version": 3,
  "name": "SF Vault+",
  "description": "Secure offline credential organizer with nested folders and login autofill for Salesforce professionals.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/logo-16.png",
      "32": "assets/icons/logo-32.png",
      "48": "assets/icons/logo-48.png",
      "128": "assets/icons/logo-128.png"
    }
  },
  "icons": {
    "16": "assets/icons/logo-16.png",
    "32": "assets/icons/logo-32.png",
    "48": "assets/icons/logo-48.png",
    "128": "assets/icons/logo-128.png"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://login.salesforce.com/*",
    "*://test.salesforce.com/*",
    "*://*.my.salesforce.com/*",
    "*://*.force.com/*",
    "*://*.my.site.com/*",
    "*://*.mil.site.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}